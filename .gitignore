# AI Personal Intelligence Copilot — .gitignore

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
*.key
secrets/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
venv/
.venv/
env/
ENV/
pip-wheel-metadata/

# ── Runtime Data (regenerated) ───────────────────────────────────────────────
data/faiss_index.index
data/faiss_index.meta
data/chroma_db/
data/copilot.db
models/hf_cache/

# ── Test / Coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker ───────────────────────────────────────────────────────────────────
.dockerignore

# ── Node (if adding a React frontend later) ───────────────────────────────────
node_modules/
