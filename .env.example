# AI Personal Intelligence Copilot — Environment Configuration
# ============================================================
# FREE API STACK — No credit card required
# ============================================================

# ── Groq API (FREE) ──────────────────────────────────────────
# Sign up at https://console.groq.com — no credit card needed
# Free tier: 14,400 requests/day, 30 req/min
GROQ_API_KEY=your_groq_api_key_here

# Available free models (pick one):
#   llama-3.3-70b-versatile   ← RECOMMENDED (best quality)
#   llama-3.1-8b-instant      ← fastest
#   mixtral-8x7b-32768        ← best for long documents (32k context)
#   gemma2-9b-it              ← Google Gemma 2
GROQ_MODEL=llama-3.3-70b-versatile

# ── HuggingFace Embeddings (FREE, LOCAL — no key needed) ─────
# Runs 100% on your machine, zero API cost
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_CACHE_DIR=./models/hf_cache

# ── Vector Database (FREE, LOCAL) ────────────────────────────
VECTOR_DB_TYPE=faiss
FAISS_INDEX_PATH=./data/faiss_index
CHROMA_DB_PATH=./data/chroma_db

# ── Database (FREE, LOCAL) ────────────────────────────────────
DATABASE_URL=sqlite:///./data/copilot.db

# ── Backend ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── RAG Settings ─────────────────────────────────────────────
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.35
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Generation ───────────────────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ============================================================
# HOW TO GET YOUR FREE GROQ API KEY:
# 1. Go to https://console.groq.com
# 2. Sign up with Google/GitHub (no credit card)
# 3. Go to API Keys → Create API Key
# 4. Copy the key and paste it above
# ============================================================
